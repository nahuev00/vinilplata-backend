// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STATION
}
enum ShippingType {
  RGE
  RETIRA
  CORREO
  EXPRESO
}

// Estados de la Orden Completa
enum OrderStatus {
  PRESUPUESTADO   // Aún no confirmado
  EN_PRODUCCION   // En producción
  TERMINADO       // Listo para retiro o envío
  ENTREGADO       // Entregado / Despachado
  CANCELADO       // Cancelado
}

// Estados del Renglón (Para la pantalla de los maquinistas/estaciones)
enum ItemStatus {
  PREIMPRESION    // Diseño / Esperando Prueba
  EN_COLA         // En cola de máquina
  IMPRESO         // Impreso (Como en tu Excel)
  TERMINACIONES   // Trabajo Posterior
  REALIZADO       // Realizado / Listo (Como en tu Excel)
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  name String
  password String?
  role Role

  ordersSold          Order[]       @relation("OrderCreatedBy")
  assignedJobs        OrderItem[]   @relation("ItemAssignedTo")

  //Materiales admitidos por cada USER{role:STATION}
  materials Material[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}


model Material{
  id Int @id @default(autoincrement())
  name String @unique
  description String?

  stations User[]

  orderItems OrderItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// Nueva Entidad: LOCALIDAD (City)
model City {
  id        Int      @id @default(autoincrement())
  name      String   @unique // Ej: "Mar del Plata", "Ayacucho"
  province  String?  // Opcional, ya que en el Excel actual viene vacío o junto al nombre
  
  // Relación: Una localidad puede tener muchos clientes
  clients Client[]

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Nueva Entidad: Comisionista / Transporte (Carrier)
model Carrier {
  id          Int      @id @default(autoincrement())
  name        String   @unique  // Ej: "Bairex", "Mdq - Carlos"
  contactInfo String?  // Ej: "LLAMAR HASTA LAS 13"
  phone       String?  // Ej: "155904404"
  pickupDays  String?  // Ej: "Lunes - Miércoles - Viernes"
  locations   String?  // Ej: "Tres Arroyos - Bahia Blanca" (Como texto de referencia)
  arrivalTime String?  // Ej: "15.30"
  
  // Relación: Un comisionista puede ser el transporte por defecto de muchos clientes
  clients Client[]

  orders Order[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Nueva Entidad: RUBRO (Category)
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique // Ej: "3D", "Agencia", "CARTELERO"
  
  // Relación: Un rubro puede tener muchos clientes
  clients   Client[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client{
  id Int @id @default(autoincrement())
  searchName String? // Nombre de Busqueda (Ej: "7 Perros Producciones SRL")
  code String @unique // Codigo (Ej: "7PE001")
  name         String   // inau / Razón Social real
  address      String?  // Direccion
  
  cityId       Int?
  city         City?    @relation(fields: [cityId], references: [id])// Localidad (Ej: "Mar del Plata")

  phone        String?  // Telefono
  email        String?  // Mail
  altPhone     String?  // Otro Telefono
  taxCategory  String?  // Condicion IVA (Ej: "Responsable Inscripto")
  cuitDni      String?  // CUIT / DNI
  discount     Float    @default(0) // Descuento (Ej: 0.3 para 30%)
  shippingType ShippingType?  // Tipo Envio (Ej: "RETIRA")

  carrierId    Int?
  carrier      Carrier? @relation(fields: [carrierId], references: [id])
  
  paymentTerms String?  // Como Paga (Ej: "Siempre Final 10%")
  notes        String?  // Observaciones
  userMercadoPago String? 

  categoryId   Int?     // El ID del rubro
  category     Category? @relation(fields: [categoryId], references: [id]) // Rubro (Ej: "GREMIO", "Sublimacion")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

//--------------ORDENES---------------
model Order {
  id                  Int          @id @default(autoincrement())
  orderNumber         String       @unique // Ej: "1038" o "ORD-1038"
  title               String?      // Referencia rápida
  
  // Relaciones
  clientId            Int
  client              Client       @relation(fields: [clientId], references: [id])
  
  sellerId            Int          // Vendedor / Quien tomó el pedido
  seller              User         @relation("OrderCreatedBy", fields: [sellerId], references: [id])
  
  // Logística 
  shippingType        ShippingType? 
  carrierId           Int?          
  carrier             Carrier?     @relation(fields: [carrierId], references: [id])
  cityId              Int?          
  city                City?        @relation(fields: [cityId], references: [id])
  
  status              OrderStatus  @default(EN_PRODUCCION)
  promisedDate        String?      // Ej: "Imprimir hoy antes de las 17hs"
  
  // Contabilidad 
  total               Float        @default(0) 
  electronicPayment   Float        @default(0) // Transferencias / MP
  cashPayment         Float        @default(0) // Efectivo
  invoiceType         String?      // Ej: "A", "B", "X"
  invoiceNumber       String?      // Ej: "X-0001-00015732"
  
  notes               String?      // Observaciones generales
  
  items               OrderItem[]  
  
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model OrderItem {
  id                  Int          @id @default(autoincrement())
  
  orderId             Int
  order               Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Asignación de Trabajo (Puede ser un Operador Humano o una Estación como "GZ_180")
  assignedToId        Int?         
  assignedTo          User?        @relation("ItemAssignedTo", fields: [assignedToId], references: [id])
  
  materialId          Int
  material            Material     @relation(fields: [materialId], references: [id])
  
  fileName            String?      // Ej: "proyecto vinilplata A 3540x870.jpg"
  
  // Dimensiones en Milímetros
  widthMm             Int          // Ancho
  heightMm            Int          // Largo
  copies              Int          @default(1) // Cantidad
  
  // Resultados calculados 
  areaM2              Float        // (widthMm * heightMm / 1000000) * copies
  linearMeters        Float?       
  
  finishing           String?      // Trabajo Posterior (Ej: "Pelar y transfer")
  notes               String?      // Observaciones (Ej: "seteo M al 75%")
  
  // Precios
  unitPrice           Float        // Valor por unidad
  subtotal            Float        
  
  status              ItemStatus   @default(PREIMPRESION)
  proofApproved       Boolean      @default(false) // ¿Prueba aprobada?
  
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}