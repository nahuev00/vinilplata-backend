generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role{
  ADMIN
  STATION
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  name String
  password String?
  role Role

  //orders Order[]

  //Materiales admitidos por cada USER{role:STATION}
  materials Material[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}


model Material{
  id Int @id @default(autoincrement())
  name String @unique
  description String?

  stations User[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}