          "name": "Asignar material a estación",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"materialId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/:userId/materials",
              "host": ["{{base_url}}"],
              "path": ["users", ":userId", "materials"],
              "variable": [
                {
                  "key": "userId",
                  "value": "1"
                }
              ]
            },
            "description": "Asigna un material a una estación (usuario con rol STATION). Ambos IDs deben ser números válidos."
          },
          "response": []
        },
        {
          "name": "Remover material de estación",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"materialId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/:userId/materials",
              "host": ["{{base_url}}"],
              "path": ["users", ":userId", "materials"],
              "variable": [
                {
                  "key": "userId",
                  "value": "1"
                }
              ]
            },
            "description": "Remueve un material de una estación. Ambos IDs deben ser números válidos. El materialId se envía en el body."
          },
          "response": []
        }
      ]
